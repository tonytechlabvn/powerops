# Generated by TerraBot — hybrid/wireguard-vpn template
# Environment: {{ environment }}
# Architecture: Proxmox VM (on-premise) + AWS EC2, connected via WireGuard VPN

# ---------------------------------------------------------------------------
# Providers
# ---------------------------------------------------------------------------
terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    proxmox = {
      source  = "telmate/proxmox"
      version = "~> 2.9"
    }
    tls = {
      source  = "hashicorp/tls"
      version = "~> 4.0"
    }
  }
}

provider "aws" {
  region = "{{ aws_region }}"
}

provider "proxmox" {
  pm_api_url      = "{{ proxmox_api_url }}"
  pm_tls_insecure = {{ 'true' if proxmox_tls_insecure | default(false) else 'false' }}
  # Credentials via PROXMOX_USERNAME / PROXMOX_PASSWORD env vars
  # or pm_api_token_id / pm_api_token_secret for token auth
}

# ---------------------------------------------------------------------------
# Variables — WireGuard Keys (pre-generated via scripts/generate-wg-keys.sh)
# ---------------------------------------------------------------------------
variable "wg_server_private_key" {
  description = "WireGuard server private key (base64). Generate with: wg genkey"
  type        = string
  sensitive   = true
}

variable "wg_server_public_key" {
  description = "WireGuard server public key (base64). Generate with: echo <private> | wg pubkey"
  type        = string
}

variable "wg_client_private_key" {
  description = "WireGuard client private key (base64). Generate with: wg genkey"
  type        = string
  sensitive   = true
}

variable "wg_client_public_key" {
  description = "WireGuard client public key (base64). Generate with: echo <private> | wg pubkey"
  type        = string
}

# ---------------------------------------------------------------------------
# SSH Key for Proxmox VM Access
# ---------------------------------------------------------------------------
resource "tls_private_key" "ssh" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

# ---------------------------------------------------------------------------
# AWS Security Group — WireGuard + SSH
# ---------------------------------------------------------------------------
resource "aws_security_group" "wireguard" {
  name_prefix = "{{ instance_name }}-wg-sg-"
  description = "Security group for {{ instance_name }} WireGuard VPN server"

  lifecycle {
    create_before_destroy = true
  }

  # WireGuard VPN (UDP)
  ingress {
    description = "WireGuard VPN"
    from_port   = {{ wg_listen_port }}
    to_port     = {{ wg_listen_port }}
    protocol    = "udp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # SSH (restricted)
  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["{{ allowed_ssh_cidr }}"]
  }

  # All outbound
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "{{ instance_name }}-wg-sg"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
  }
}

{% if use_elastic_ip | default(true) %}
# ---------------------------------------------------------------------------
# Elastic IP — stable public IP for WireGuard endpoint (survives stop/start)
# ---------------------------------------------------------------------------
resource "aws_eip" "wireguard" {
  domain = "vpc"

  tags = {
    Name        = "{{ instance_name }}-eip"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
  }
}

resource "aws_eip_association" "wireguard" {
  instance_id   = aws_instance.wireguard_server.id
  allocation_id = aws_eip.wireguard.id
}
{% endif %}

{% if auto_key_pair | default(false) %}
# ---------------------------------------------------------------------------
# Auto-generated AWS SSH Key Pair
# ---------------------------------------------------------------------------
resource "aws_key_pair" "generated" {
  key_name   = "{{ instance_name }}-key"
  public_key = tls_private_key.ssh.public_key_openssh

  tags = {
    Name        = "{{ instance_name }}-key"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
  }
}
{% endif %}

# ---------------------------------------------------------------------------
# AWS EC2 Instance — WireGuard Server
# ---------------------------------------------------------------------------
resource "aws_instance" "wireguard_server" {
  ami                    = "{{ ami_id }}"
  instance_type          = "{{ instance_type }}"
{% if auto_key_pair | default(false) %}
  key_name               = aws_key_pair.generated.key_name
{% else %}
  key_name               = "{{ key_name }}"
{% endif %}
  vpc_security_group_ids = [aws_security_group.wireguard.id]

  root_block_device {
    volume_type           = "gp3"
    volume_size           = {{ root_volume_size_gb }}
    delete_on_termination = true
    encrypted             = true
  }

  metadata_options {
    http_tokens = "required" # IMDSv2 enforced
  }

  # Cloud-init: install WireGuard packages only (config delivered via provisioner)
  user_data = base64encode(<<-CLOUDINIT
#cloud-config
package_update: true

packages:
  - wireguard
  - wireguard-tools

write_files:
  - path: /etc/sysctl.d/99-wireguard.conf
    permissions: '0644'
    content: |
      net.ipv4.ip_forward = 1

runcmd:
  - sysctl -p /etc/sysctl.d/99-wireguard.conf
CLOUDINIT
  )

  tags = {
    Name        = "{{ instance_name }}"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
    Role        = "wireguard-server"
  }

  # Deliver WireGuard server config via provisioner (keeps private key out of user_data)
  provisioner "file" {
    content = <<-WGCONF
[Interface]
PrivateKey = ${var.wg_server_private_key}
Address = {{ wg_server_ip }}/24
ListenPort = {{ wg_listen_port }}
PostUp = ETH=$(ip route show default | awk '{print $5}'); iptables -A FORWARD -i wg0 -j ACCEPT; iptables -A FORWARD -o wg0 -j ACCEPT; iptables -t nat -A POSTROUTING -o $ETH -j MASQUERADE
PostDown = ETH=$(ip route show default | awk '{print $5}'); iptables -D FORWARD -i wg0 -j ACCEPT; iptables -D FORWARD -o wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o $ETH -j MASQUERADE

[Peer]
PublicKey = ${var.wg_client_public_key}
AllowedIPs = {{ wg_client_ip }}/32
WGCONF

    destination = "/tmp/wg0.conf"

    connection {
      type        = "ssh"
      user        = "ubuntu"
{% if auto_key_pair | default(false) %}
      private_key = tls_private_key.ssh.private_key_pem
{% else %}
      private_key = file("{{ ec2_ssh_private_key_path | default('~/.ssh/id_rsa') }}")
{% endif %}
      host        = self.public_ip
      timeout     = "5m"
    }
  }

  provisioner "remote-exec" {
    inline = [
      "cloud-init status --wait > /dev/null 2>&1 || true",
      "sudo mv /tmp/wg0.conf /etc/wireguard/wg0.conf",
      "sudo chmod 600 /etc/wireguard/wg0.conf",
      "sudo systemctl enable wg-quick@wg0",
      "sudo systemctl start wg-quick@wg0",
    ]

    connection {
      type        = "ssh"
      user        = "ubuntu"
{% if auto_key_pair | default(false) %}
      private_key = tls_private_key.ssh.private_key_pem
{% else %}
      private_key = file("{{ ec2_ssh_private_key_path | default('~/.ssh/id_rsa') }}")
{% endif %}
      host        = self.public_ip
      timeout     = "5m"
    }
  }
}

# ---------------------------------------------------------------------------
# Proxmox VM — WireGuard Client
# ---------------------------------------------------------------------------
resource "proxmox_vm_qemu" "wireguard_client" {
  target_node = "{{ proxmox_node }}"
  vmid        = {{ vm_id }}
  name        = "{{ vm_name }}"
  desc        = "WireGuard VPN client — managed by TerraBot"

  # Clone from existing cloud-init template
  clone      = "{{ template_name }}"
  full_clone = true

  # Hardware
  cores  = {{ cores }}
  memory = {{ memory_mb }}
  agent  = 1 # QEMU guest agent enabled

  disk {
    slot    = "scsi0"
    size    = "{{ disk_size_gb }}G"
    type    = "scsi"
    storage = "{{ storage_pool }}"
    ssd     = 1
    discard = "on"
  }

  network {
    model  = "virtio"
    bridge = "vmbr0"
  }

  # Cloud-init configuration
  os_type   = "cloud-init"
  ipconfig0 = {% if proxmox_vm_ip == "dhcp" %}"ip=dhcp"{% else %}"ip={{ proxmox_vm_ip }}{% if proxmox_vm_gateway %},gw={{ proxmox_vm_gateway }}{% endif %}"{% endif %}

  sshkeys = <<-EOT
    ${tls_private_key.ssh.public_key_openssh}
  EOT

  lifecycle {
    ignore_changes = [
      network, # Prevent drift on MAC address assignment
    ]
  }

  tags = "{{ environment }},terrabot,wireguard-client"

  # Depends on EC2 instance to get its public IP for WireGuard endpoint
  depends_on = [aws_instance.wireguard_server]

  # ---------------------------------------------------------------------------
  # Provisioner: deliver WireGuard config to Proxmox VM
  # ---------------------------------------------------------------------------
  provisioner "file" {
    content = <<-WGCONF
[Interface]
PrivateKey = ${var.wg_client_private_key}
Address = {{ wg_client_ip }}/24

[Peer]
PublicKey = ${var.wg_server_public_key}
{% if use_elastic_ip | default(true) %}Endpoint = ${aws_eip.wireguard.public_ip}:{{ wg_listen_port }}{% else %}Endpoint = ${aws_instance.wireguard_server.public_ip}:{{ wg_listen_port }}{% endif %}
AllowedIPs = {{ wg_server_ip }}/32{% if wg_extra_allowed_ips %}, {{ wg_extra_allowed_ips }}{% endif %}
PersistentKeepalive = 25
WGCONF

    destination = "/tmp/wg0.conf"

    connection {
      type        = "ssh"
      user        = "{{ proxmox_ssh_user | default('ubuntu') }}"
      private_key = tls_private_key.ssh.private_key_pem
      host        = self.default_ipv4_address
      timeout     = "5m"
    }
  }

  provisioner "remote-exec" {
    inline = [
      "sudo apt-get update -qq",
      "sudo apt-get install -y -qq wireguard wireguard-tools > /dev/null 2>&1",
      "sudo mv /tmp/wg0.conf /etc/wireguard/wg0.conf",
      "sudo chmod 600 /etc/wireguard/wg0.conf",
      "sudo sysctl -w net.ipv4.ip_forward=1",
      "echo 'net.ipv4.ip_forward = 1' | sudo tee /etc/sysctl.d/99-wireguard.conf",
      "sudo systemctl enable wg-quick@wg0",
      "sudo systemctl start wg-quick@wg0",
    ]

    connection {
      type        = "ssh"
      user        = "{{ proxmox_ssh_user | default('ubuntu') }}"
      private_key = tls_private_key.ssh.private_key_pem
      host        = self.default_ipv4_address
      timeout     = "5m"
    }
  }
}

# ---------------------------------------------------------------------------
# Outputs
# ---------------------------------------------------------------------------
output "ec2_instance_id" {
  description = "AWS EC2 instance ID"
  value       = aws_instance.wireguard_server.id
}

output "ec2_public_ip" {
  description = "EC2 WireGuard server public IP"
{% if use_elastic_ip | default(true) %}
  value       = aws_eip.wireguard.public_ip
{% else %}
  value       = aws_instance.wireguard_server.public_ip
{% endif %}
}

output "ec2_wireguard_tunnel_ip" {
  description = "EC2 WireGuard tunnel IP"
  value       = "{{ wg_server_ip }}"
}

output "proxmox_vm_id" {
  description = "Proxmox VM ID"
  value       = proxmox_vm_qemu.wireguard_client.vmid
}

output "proxmox_vm_ip" {
  description = "Proxmox VM LAN IP"
  value       = proxmox_vm_qemu.wireguard_client.default_ipv4_address
}

output "proxmox_wireguard_tunnel_ip" {
  description = "Proxmox WireGuard tunnel IP"
  value       = "{{ wg_client_ip }}"
}

output "wireguard_status_commands" {
  description = "Commands to verify WireGuard VPN connectivity"
  value       = <<-EOT
    # On EC2 (server):
    ssh -i key.pem ubuntu@${aws_instance.wireguard_server.public_ip} 'sudo wg show'

    # On Proxmox VM (client):
    ssh ubuntu@${proxmox_vm_qemu.wireguard_client.default_ipv4_address} 'sudo wg show'

    # Test tunnel connectivity (from Proxmox VM):
    ssh ubuntu@${proxmox_vm_qemu.wireguard_client.default_ipv4_address} 'ping -c 3 {{ wg_server_ip }}'

    # Test tunnel connectivity (from EC2):
    ssh -i key.pem ubuntu@${aws_instance.wireguard_server.public_ip} 'ping -c 3 {{ wg_client_ip }}'
  EOT
}

output "ssh_private_key_pem" {
  description = "SSH private key for Proxmox VM access (save securely)"
  value       = tls_private_key.ssh.private_key_pem
  sensitive   = true
}

{% if auto_key_pair | default(false) %}
output "ec2_ssh_private_key_pem" {
  description = "SSH private key for EC2 access (save securely)"
  value       = tls_private_key.ssh.private_key_pem
  sensitive   = true
}
{% endif %}
