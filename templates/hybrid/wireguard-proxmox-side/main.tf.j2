# Generated by TerraBot — hybrid/wireguard-proxmox-side template
# Environment: {{ environment }}
# On-premise side: Proxmox VM + WireGuard client, connects to AWS WireGuard server

# ---------------------------------------------------------------------------
# Providers
# ---------------------------------------------------------------------------
terraform {
  required_version = ">= 1.5.0"
  required_providers {
    proxmox = {
      source  = "telmate/proxmox"
      version = "~> 2.9"
    }
    tls = {
      source  = "hashicorp/tls"
      version = "~> 4.0"
    }
    external = {
      source  = "hashicorp/external"
      version = "~> 2.3"
    }
  }
}

provider "proxmox" {
  pm_api_url      = "{{ proxmox_api_url }}"
  pm_tls_insecure = {{ 'true' if proxmox_tls_insecure | default(false) else 'false' }}
  # Credentials via PROXMOX_USERNAME / PROXMOX_PASSWORD env vars
}

# ---------------------------------------------------------------------------
# Auto Key Generation — WireGuard Client (cached, idempotent)
# ---------------------------------------------------------------------------
data "external" "wg_client_keys" {
  program = ["bash", "${path.module}/scripts/generate-wg-keys.sh"]
  query   = { key_id = "client" }
}

# ---------------------------------------------------------------------------
# SSH Key for VM Access
# ---------------------------------------------------------------------------
resource "tls_private_key" "ssh" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

# ---------------------------------------------------------------------------
# Proxmox VM — WireGuard Client
# ---------------------------------------------------------------------------
resource "proxmox_vm_qemu" "wireguard_client" {
  target_node = "{{ proxmox_node }}"
  vmid        = {{ vm_id }}
  name        = "{{ vm_name }}"
  desc        = "WireGuard VPN client — connects to AWS ({{ wg_server_endpoint }})"

  clone      = "{{ template_name }}"
  full_clone = true

  cores  = {{ cores }}
  memory = {{ memory_mb }}
  agent  = 1

  disk {
    slot    = "scsi0"
    size    = "{{ disk_size_gb }}G"
    type    = "scsi"
    storage = "{{ storage_pool }}"
    ssd     = 1
    discard = "on"
  }

  network {
    model  = "virtio"
    bridge = "vmbr0"
  }

  os_type   = "cloud-init"
  ipconfig0 = {% if proxmox_vm_ip == "dhcp" %}"ip=dhcp"{% else %}"ip={{ proxmox_vm_ip }}{% if proxmox_vm_gateway %},gw={{ proxmox_vm_gateway }}{% endif %}"{% endif %}

  sshkeys = <<-EOT
    ${tls_private_key.ssh.public_key_openssh}
  EOT

  lifecycle {
    ignore_changes = [network]
  }

  tags = "{{ environment }},terrabot,wireguard-client"

  # ---------------------------------------------------------------------------
  # Provisioner: install WireGuard + deliver config
  # ---------------------------------------------------------------------------
  provisioner "file" {
    content = <<-WGCONF
[Interface]
PrivateKey = ${data.external.wg_client_keys.result.private_key}
Address = {{ wg_client_ip }}/24

[Peer]
# AWS WireGuard server
PublicKey = {{ wg_server_public_key }}
Endpoint = {{ wg_server_endpoint }}
AllowedIPs = {{ wg_server_ip }}/32{% if aws_vpc_cidr %}, {{ aws_vpc_cidr }}{% endif %}
PersistentKeepalive = 25
WGCONF

    destination = "/tmp/wg0.conf"

    connection {
      type        = "ssh"
      user        = "{{ proxmox_ssh_user | default('ubuntu') }}"
      private_key = tls_private_key.ssh.private_key_pem
      host        = self.default_ipv4_address
      timeout     = "5m"
    }
  }

  provisioner "remote-exec" {
    inline = [
      "sudo apt-get update -qq",
      "sudo apt-get install -y -qq wireguard wireguard-tools > /dev/null 2>&1",
      "sudo mv /tmp/wg0.conf /etc/wireguard/wg0.conf",
      "sudo chmod 600 /etc/wireguard/wg0.conf",
      "sudo sysctl -w net.ipv4.ip_forward=1",
      "echo 'net.ipv4.ip_forward = 1' | sudo tee /etc/sysctl.d/99-wireguard.conf",
      "sudo systemctl enable wg-quick@wg0",
      "sudo systemctl start wg-quick@wg0",
    ]

    connection {
      type        = "ssh"
      user        = "{{ proxmox_ssh_user | default('ubuntu') }}"
      private_key = tls_private_key.ssh.private_key_pem
      host        = self.default_ipv4_address
      timeout     = "5m"
    }
  }
}

# ---------------------------------------------------------------------------
# Outputs
# ---------------------------------------------------------------------------
output "wg_client_public_key" {
  description = "WireGuard client public key — provide this to the AWS-side template"
  value       = data.external.wg_client_keys.result.public_key
}

output "proxmox_vm_id" {
  description = "Proxmox VM ID"
  value       = proxmox_vm_qemu.wireguard_client.vmid
}

output "proxmox_vm_ip" {
  description = "Proxmox VM LAN IP"
  value       = proxmox_vm_qemu.wireguard_client.default_ipv4_address
}

output "proxmox_wg_tunnel_ip" {
  description = "WireGuard tunnel IP of this client"
  value       = "{{ wg_client_ip }}"
}

output "ssh_private_key_pem" {
  description = "SSH private key for Proxmox VM access (save securely)"
  value       = tls_private_key.ssh.private_key_pem
  sensitive   = true
}

output "verification_commands" {
  description = "Commands to verify WireGuard VPN connectivity"
  value       = <<-EOT
    # SSH to Proxmox VM:
    ssh -i key.pem {{ proxmox_ssh_user | default('ubuntu') }}@${proxmox_vm_qemu.wireguard_client.default_ipv4_address}

    # Check WireGuard status:
    ssh {{ proxmox_ssh_user | default('ubuntu') }}@${proxmox_vm_qemu.wireguard_client.default_ipv4_address} 'sudo wg show'

    # Ping AWS WireGuard server via tunnel:
    ssh {{ proxmox_ssh_user | default('ubuntu') }}@${proxmox_vm_qemu.wireguard_client.default_ipv4_address} 'ping -c 3 {{ wg_server_ip }}'
  EOT
}

output "deployment_workflow" {
  description = "Workflow to complete the VPN setup"
  value       = <<-EOT
    ## Deployment Workflow (2-step):
    #
    # Step 1: Deploy THIS template (Proxmox side) first to get client public key:
    #   terraform apply → copy wg_client_public_key output
    #
    # Step 2: Deploy hybrid/wireguard-aws-side template with:
    #   wg_client_public_key = "<paste from Step 1>"
    #
    # VPN tunnel established automatically after both sides are deployed.
  EOT
}
