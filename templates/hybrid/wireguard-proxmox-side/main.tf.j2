# Generated by TerraBot — hybrid/wireguard-proxmox-side template
# Environment: {{ environment }}
# AUTO MODE: receives all keys from AWS-side template outputs
# On-premise side: Proxmox VM + WireGuard client, connects to AWS

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    proxmox = {
      source  = "telmate/proxmox"
      version = "~> 2.9"
    }
    tls = {
      source  = "hashicorp/tls"
      version = "~> 4.0"
    }
  }
}

provider "proxmox" {
  pm_api_url      = var.proxmox_url
  pm_tls_insecure = {{ 'true' if proxmox_tls_insecure | default(false) else 'false' }}
  # Credentials via PROXMOX_USERNAME / PROXMOX_PASSWORD env vars
}

# ---------------------------------------------------------------------------
# Variables — Proxmox config from project settings
# ---------------------------------------------------------------------------
variable "proxmox_url" {
  description = "Proxmox API URL (from Config/Proxmox project credentials)"
  type        = string
}

# ---------------------------------------------------------------------------
# Variables — WireGuard keys from AWS-side output (auto mode)
# ---------------------------------------------------------------------------
variable "wg_server_public_key" {
  description = "Server public key from AWS-side template output"
  type        = string
}

variable "wg_server_endpoint" {
  description = "Server endpoint (IP:port) from AWS-side template output"
  type        = string
}

variable "wg_client_private_key" {
  description = "Client private key from AWS-side template output"
  type        = string
  sensitive   = true
}

variable "wg_client_public_key" {
  description = "Client public key from AWS-side template output"
  type        = string
}

# ---------------------------------------------------------------------------
# SSH Key for VM Access
# ---------------------------------------------------------------------------
resource "tls_private_key" "ssh" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

# ---------------------------------------------------------------------------
# Proxmox VM — WireGuard Client
# ---------------------------------------------------------------------------
resource "proxmox_vm_qemu" "wireguard_client" {
  target_node = "{{ proxmox_node }}"
  vmid        = {{ vm_id }}
  name        = "{{ vm_name }}"
  desc        = "WireGuard VPN client — connects to AWS (auto mode)"

  clone      = "{{ template_name }}"
  full_clone = true

  cores  = {{ cores }}
  memory = {{ memory_mb }}
  agent  = 1

  disk {
    slot    = "scsi0"
    size    = "{{ disk_size_gb }}G"
    type    = "scsi"
    storage = "{{ storage_pool }}"
    ssd     = 1
    discard = "on"
  }

  network {
    model  = "virtio"
    bridge = "vmbr0"
  }

  os_type   = "cloud-init"
  ipconfig0 = {% if proxmox_vm_ip == "dhcp" %}"ip=dhcp"{% else %}"ip={{ proxmox_vm_ip }}{% if proxmox_vm_gateway %},gw={{ proxmox_vm_gateway }}{% endif %}"{% endif %}

  sshkeys = <<-EOT
    ${tls_private_key.ssh.public_key_openssh}
  EOT

  lifecycle {
    ignore_changes = [network]
  }

  tags = "{{ environment }},terrabot,wireguard-client"

  # ---------------------------------------------------------------------------
  # Provisioner: install WireGuard + deliver config (auto mode — keys from AWS)
  # ---------------------------------------------------------------------------
  provisioner "file" {
    content = <<-WGCONF
[Interface]
PrivateKey = ${var.wg_client_private_key}
Address = {{ wg_client_ip }}/24

[Peer]
PublicKey = ${var.wg_server_public_key}
Endpoint = ${var.wg_server_endpoint}
AllowedIPs = {{ wg_server_ip }}/32{% if aws_vpc_cidr %}, {{ aws_vpc_cidr }}{% endif %}
PersistentKeepalive = 25
WGCONF

    destination = "/tmp/wg0.conf"

    connection {
      type        = "ssh"
      user        = "{{ proxmox_ssh_user | default('ubuntu') }}"
      private_key = tls_private_key.ssh.private_key_pem
      host        = self.default_ipv4_address
      timeout     = "5m"
    }
  }

  provisioner "remote-exec" {
    inline = [
      "sudo apt-get update -qq",
      "sudo apt-get install -y -qq wireguard wireguard-tools > /dev/null 2>&1",
      "sudo mv /tmp/wg0.conf /etc/wireguard/wg0.conf",
      "sudo chmod 600 /etc/wireguard/wg0.conf",
      "sudo sysctl -w net.ipv4.ip_forward=1",
      "echo 'net.ipv4.ip_forward = 1' | sudo tee /etc/sysctl.d/99-wireguard.conf",
      "sudo systemctl enable wg-quick@wg0",
      "sudo systemctl start wg-quick@wg0",
    ]

    connection {
      type        = "ssh"
      user        = "{{ proxmox_ssh_user | default('ubuntu') }}"
      private_key = tls_private_key.ssh.private_key_pem
      host        = self.default_ipv4_address
      timeout     = "5m"
    }
  }
}

# ---------------------------------------------------------------------------
# Outputs
# ---------------------------------------------------------------------------
output "proxmox_vm_id" {
  description = "Proxmox VM ID"
  value       = proxmox_vm_qemu.wireguard_client.vmid
}

output "proxmox_vm_ip" {
  description = "Proxmox VM LAN IP"
  value       = proxmox_vm_qemu.wireguard_client.default_ipv4_address
}

output "wg_client_public_key" {
  description = "WireGuard client public key"
  value       = var.wg_client_public_key
}

output "wg_tunnel_ip" {
  description = "WireGuard tunnel IP of this client"
  value       = "{{ wg_client_ip }}"
}

output "ssh_private_key_pem" {
  description = "SSH private key for Proxmox VM"
  value       = tls_private_key.ssh.private_key_pem
  sensitive   = true
}

output "vpn_status" {
  description = "VPN verification commands"
  value       = <<-EOT
    # Check WireGuard:
    ssh {{ proxmox_ssh_user | default('ubuntu') }}@${proxmox_vm_qemu.wireguard_client.default_ipv4_address} 'sudo wg show'

    # Ping AWS via tunnel:
    ssh {{ proxmox_ssh_user | default('ubuntu') }}@${proxmox_vm_qemu.wireguard_client.default_ipv4_address} 'ping -c 3 {{ wg_server_ip }}'
  EOT
}
