# Generated by TerraBot — hybrid/wireguard-aws-side template
# Environment: {{ environment }}
# AUTO MODE: generates ALL WireGuard keys (server + client)
# AWS side: WireGuard server (EC2) + workload VM (EC2), connects to on-premise Proxmox

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    tls = {
      source  = "hashicorp/tls"
      version = "~> 4.0"
    }
    external = {
      source  = "hashicorp/external"
      version = "~> 2.3"
    }
  }
}

provider "aws" {
  region = "{{ aws_region }}"
}

# ---------------------------------------------------------------------------
# Auto Key Generation — BOTH server AND client keys (cached, idempotent)
# ---------------------------------------------------------------------------
data "external" "wg_server_keys" {
  program = ["bash", "${path.module}/scripts/generate-wg-keys.sh"]
  query   = { key_id = "server" }
}

data "external" "wg_client_keys" {
  program = ["bash", "${path.module}/scripts/generate-wg-keys.sh"]
  query   = { key_id = "client" }
}

# ---------------------------------------------------------------------------
# SSH Key — shared for both EC2 instances
# ---------------------------------------------------------------------------
resource "tls_private_key" "ssh" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "generated" {
  key_name   = "{{ project_name }}-key"
  public_key = tls_private_key.ssh.public_key_openssh

  tags = {
    Name        = "{{ project_name }}-key"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
  }
}

# ---------------------------------------------------------------------------
# Elastic IP — stable endpoint for WireGuard
# ---------------------------------------------------------------------------
resource "aws_eip" "wireguard" {
  domain = "vpc"

  tags = {
    Name        = "{{ project_name }}-wg-eip"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
  }
}

resource "aws_eip_association" "wireguard" {
  instance_id   = aws_instance.wireguard_server.id
  allocation_id = aws_eip.wireguard.id
}

# ---------------------------------------------------------------------------
# Security Group — WireGuard Server
# ---------------------------------------------------------------------------
resource "aws_security_group" "wireguard" {
  name_prefix = "{{ project_name }}-wg-sg-"
  description = "WireGuard VPN server for {{ project_name }}"

  lifecycle { create_before_destroy = true }

  ingress {
    description = "WireGuard VPN"
    from_port   = {{ wg_listen_port }}
    to_port     = {{ wg_listen_port }}
    protocol    = "udp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["{{ allowed_ssh_cidr }}"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "{{ project_name }}-wg-sg"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
  }
}

# ---------------------------------------------------------------------------
# Security Group — Workload VM
# ---------------------------------------------------------------------------
resource "aws_security_group" "workload" {
  name_prefix = "{{ project_name }}-vm-sg-"
  description = "Workload VM for {{ project_name }}"

  lifecycle { create_before_destroy = true }

  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["{{ allowed_ssh_cidr }}"]
  }

  ingress {
    description = "From WireGuard tunnel"
    from_port   = 0
    to_port     = 65535
    protocol    = "tcp"
    cidr_blocks = ["{{ wg_tunnel_cidr }}"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "{{ project_name }}-vm-sg"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
  }
}

# ---------------------------------------------------------------------------
# EC2 — WireGuard Server
# ---------------------------------------------------------------------------
resource "aws_instance" "wireguard_server" {
  ami                    = "{{ ami_id }}"
  instance_type          = "{{ wg_instance_type }}"
  key_name               = aws_key_pair.generated.key_name
  vpc_security_group_ids = [aws_security_group.wireguard.id]

  root_block_device {
    volume_type           = "gp3"
    volume_size           = 20
    delete_on_termination = true
    encrypted             = true
  }

  metadata_options {
    http_tokens = "required"
  }

  user_data = base64encode(<<-CLOUDINIT
#cloud-config
package_update: true
packages:
  - wireguard
  - wireguard-tools
write_files:
  - path: /etc/sysctl.d/99-wireguard.conf
    permissions: '0644'
    content: |
      net.ipv4.ip_forward = 1
runcmd:
  - sysctl -p /etc/sysctl.d/99-wireguard.conf
CLOUDINIT
  )

  tags = {
    Name        = "{{ project_name }}-wg-server"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
    Role        = "wireguard-server"
  }

  provisioner "file" {
    content = <<-WGCONF
[Interface]
PrivateKey = ${data.external.wg_server_keys.result.private_key}
Address = {{ wg_server_ip }}/24
ListenPort = {{ wg_listen_port }}
PostUp = ETH=$(ip route show default | awk '{print $5}'); iptables -A FORWARD -i wg0 -j ACCEPT; iptables -A FORWARD -o wg0 -j ACCEPT; iptables -t nat -A POSTROUTING -o $ETH -j MASQUERADE
PostDown = ETH=$(ip route show default | awk '{print $5}'); iptables -D FORWARD -i wg0 -j ACCEPT; iptables -D FORWARD -o wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o $ETH -j MASQUERADE

[Peer]
PublicKey = ${data.external.wg_client_keys.result.public_key}
AllowedIPs = {{ wg_client_ip }}/32{% if onprem_subnet %}, {{ onprem_subnet }}{% endif %}
WGCONF

    destination = "/tmp/wg0.conf"

    connection {
      type        = "ssh"
      user        = "ubuntu"
      private_key = tls_private_key.ssh.private_key_pem
      host        = self.public_ip
      timeout     = "5m"
    }
  }

  provisioner "remote-exec" {
    inline = [
      "cloud-init status --wait > /dev/null 2>&1 || true",
      "sudo mv /tmp/wg0.conf /etc/wireguard/wg0.conf",
      "sudo chmod 600 /etc/wireguard/wg0.conf",
      "sudo systemctl enable wg-quick@wg0",
      "sudo systemctl start wg-quick@wg0",
    ]

    connection {
      type        = "ssh"
      user        = "ubuntu"
      private_key = tls_private_key.ssh.private_key_pem
      host        = self.public_ip
      timeout     = "5m"
    }
  }
}

# ---------------------------------------------------------------------------
# EC2 — Workload VM
# ---------------------------------------------------------------------------
resource "aws_instance" "workload_vm" {
  ami                    = "{{ ami_id }}"
  instance_type          = "{{ vm_instance_type }}"
  key_name               = aws_key_pair.generated.key_name
  vpc_security_group_ids = [aws_security_group.workload.id]

  root_block_device {
    volume_type           = "gp3"
    volume_size           = {{ vm_volume_size_gb }}
    delete_on_termination = true
    encrypted             = true
  }

  metadata_options {
    http_tokens = "required"
  }

  tags = {
    Name        = "{{ project_name }}-vm"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
    Role        = "workload"
  }
}

# ---------------------------------------------------------------------------
# Outputs — AUTO MODE: everything the Proxmox side needs
# ---------------------------------------------------------------------------
output "wg_server_public_key" {
  description = "WireGuard server public key (auto-generated)"
  value       = data.external.wg_server_keys.result.public_key
}

output "wg_client_private_key" {
  description = "WireGuard client private key — feed to Proxmox-side template"
  value       = data.external.wg_client_keys.result.private_key
  sensitive   = true
}

output "wg_client_public_key" {
  description = "WireGuard client public key (auto-generated)"
  value       = data.external.wg_client_keys.result.public_key
}

output "wg_server_endpoint" {
  description = "WireGuard server endpoint (EIP:port)"
  value       = "${aws_eip.wireguard.public_ip}:{{ wg_listen_port }}"
}

output "wg_server_eip" {
  description = "Elastic IP of WireGuard server"
  value       = aws_eip.wireguard.public_ip
}

output "workload_vm_public_ip" {
  description = "Workload VM public IP"
  value       = aws_instance.workload_vm.public_ip
}

output "workload_vm_private_ip" {
  description = "Workload VM private IP"
  value       = aws_instance.workload_vm.private_ip
}

output "ssh_private_key_pem" {
  description = "SSH private key for EC2 instances"
  value       = tls_private_key.ssh.private_key_pem
  sensitive   = true
}

output "proxmox_side_config" {
  description = "Auto-generated config to pass to hybrid/wireguard-proxmox-side template"
  value       = <<-EOT
    ## Copy these values to the Proxmox-side template variables:
    wg_server_public_key  = "${data.external.wg_server_keys.result.public_key}"
    wg_server_endpoint    = "${aws_eip.wireguard.public_ip}:{{ wg_listen_port }}"
    wg_client_private_key = <sensitive — run: terraform output -raw wg_client_private_key>
    wg_client_public_key  = "${data.external.wg_client_keys.result.public_key}"
  EOT
}
