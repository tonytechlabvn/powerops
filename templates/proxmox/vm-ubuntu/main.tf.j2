# Generated by TerraBot — proxmox/vm-ubuntu template
# Environment: {{ environment }}

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    proxmox = {
      source  = "telmate/proxmox"
      version = "~> 2.9"
    }
  }
}

provider "proxmox" {
  pm_api_url      = "{{ proxmox_api_url }}"
  pm_tls_insecure = false
  # Credentials supplied via PROXMOX_USERNAME / PROXMOX_PASSWORD env vars
  # or pm_api_token_id / pm_api_token_secret for token auth
}

# ---------------------------------------------------------------------------
# Ubuntu VM cloned from cloud-init template
# ---------------------------------------------------------------------------
resource "proxmox_vm_qemu" "ubuntu" {
  target_node = "{{ proxmox_node }}"
  vmid        = {{ vm_id }}
  name        = "{{ vm_name }}"

  # Clone from existing cloud-init template
  clone      = "{{ template_name }}"
  full_clone = true

  # Hardware
  cores  = {{ cores }}
  memory = {{ memory_mb }}
  agent  = 1 # QEMU guest agent enabled

  disk {
    slot    = "scsi0"
    size    = "{{ disk_size_gb }}G"
    type    = "scsi"
    storage = "{{ storage_pool }}"
    ssd     = 1
    discard = "on"
  }

  network {
    model  = "virtio"
    bridge = "vmbr0"
  }

  # Cloud-init configuration
  os_type    = "cloud-init"
  ipconfig0  = {% if ip_address == "dhcp" %}"ip=dhcp"{% else %}"ip={{ ip_address }}{% if gateway %},gw={{ gateway }}{% endif %}"{% endif %}

  sshkeys = <<-EOT
    {{ ssh_public_key }}
  EOT

  lifecycle {
    ignore_changes = [
      network,  # prevent drift on MAC address assignment
    ]
  }

  tags = "{{ environment }},terrabot"
}

# ---------------------------------------------------------------------------
# Outputs
# ---------------------------------------------------------------------------
output "vm_id" {
  description = "Proxmox VM ID"
  value       = proxmox_vm_qemu.ubuntu.vmid
}

output "vm_name" {
  description = "VM hostname"
  value       = proxmox_vm_qemu.ubuntu.name
}

output "ip_address" {
  description = "Assigned IP address (may be empty until guest agent reports it)"
  value       = proxmox_vm_qemu.ubuntu.default_ipv4_address
}
