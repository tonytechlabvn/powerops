# Generated by TerraBot — aws/ec2-web-server template
# Environment: {{ environment }}

terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
{% if auto_key_pair | default(false) %}
    tls = {
      source  = "hashicorp/tls"
      version = "~> 4.0"
    }
{% endif %}
  }
}

provider "aws" {
  region = "{{ aws_region }}"
}

{% if auto_key_pair | default(false) %}
# ---------------------------------------------------------------------------
# Auto-generated SSH key pair
# ---------------------------------------------------------------------------
resource "tls_private_key" "ssh" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "generated" {
  key_name   = "{{ instance_name }}-key"
  public_key = tls_private_key.ssh.public_key_openssh

  tags = {
    Name        = "{{ instance_name }}-key"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
  }
}
{% endif %}

# ---------------------------------------------------------------------------
# Security group — HTTP, HTTPS, and SSH ingress
# ---------------------------------------------------------------------------
resource "aws_security_group" "web" {
  name        = "{{ instance_name }}-sg"
  description = "Security group for {{ instance_name }} web server"

  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTPS"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["{{ allowed_ssh_cidr }}"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "{{ instance_name }}-sg"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
  }
}

# ---------------------------------------------------------------------------
# EC2 instance
# ---------------------------------------------------------------------------
resource "aws_instance" "web" {
  ami                    = "{{ ami_id }}"
  instance_type          = "{{ instance_type }}"
{% if auto_key_pair | default(false) %}
  key_name               = aws_key_pair.generated.key_name
{% else %}
  key_name               = "{{ key_name }}"
{% endif %}
  vpc_security_group_ids = [aws_security_group.web.id]

  root_block_device {
    volume_type           = "gp3"
    volume_size           = {{ root_volume_size_gb }}
    delete_on_termination = true
    encrypted             = true
  }

  metadata_options {
    http_tokens = "required" # IMDSv2 enforced
  }

  tags = {
    Name        = "{{ instance_name }}"
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
  }
}

# ---------------------------------------------------------------------------
# Outputs
# ---------------------------------------------------------------------------
output "instance_id" {
  description = "EC2 instance ID"
  value       = aws_instance.web.id
}

output "public_ip" {
  description = "Public IP address of the web server"
  value       = aws_instance.web.public_ip
}

output "public_dns" {
  description = "Public DNS hostname of the web server"
  value       = aws_instance.web.public_dns
}

{% if auto_key_pair | default(false) %}
output "ssh_command" {
  description = "SSH command to connect to the server"
  value       = "ssh -i key.pem {{ ssh_user }}@${aws_instance.web.public_ip}"
}

output "private_key_pem" {
  description = "SSH private key (save this — it cannot be retrieved again)"
  value       = tls_private_key.ssh.private_key_pem
  sensitive   = true
}
{% endif %}
