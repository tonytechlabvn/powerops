terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "{{ aws_region }}"
}

locals {
  subnet_ids_list = split(",", "{{ subnet_ids }}")

  common_tags = {
    Environment = "{{ environment }}"
    ManagedBy   = "TerraBot"
  }
}

# ---------------------------------------------------------------------------
# Security group for RDS
# ---------------------------------------------------------------------------

resource "aws_security_group" "rds" {
  name        = "{{ db_name }}-rds-sg"
  description = "Allow PostgreSQL access from within VPC"
  vpc_id      = "{{ vpc_id }}"

  ingress {
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "PostgreSQL"
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = merge(local.common_tags, {
    Name = "{{ db_name }}-rds-sg"
  })
}

# ---------------------------------------------------------------------------
# DB subnet group
# ---------------------------------------------------------------------------

resource "aws_db_subnet_group" "main" {
  name        = "{{ db_name }}-subnet-group"
  subnet_ids  = [for s in local.subnet_ids_list : trimspace(s)]
  description = "Subnet group for {{ db_name }} RDS instance"

  tags = merge(local.common_tags, {
    Name = "{{ db_name }}-subnet-group"
  })
}

# ---------------------------------------------------------------------------
# Parameter group
# ---------------------------------------------------------------------------

resource "aws_db_parameter_group" "main" {
  name        = "{{ db_name }}-pg15"
  family      = "postgres15"
  description = "Parameter group for {{ db_name }}"

  parameter {
    name  = "log_connections"
    value = "1"
  }

  tags = local.common_tags
}

# ---------------------------------------------------------------------------
# RDS instance
# ---------------------------------------------------------------------------

resource "aws_db_instance" "main" {
  identifier              = "{{ db_name }}"
  engine                  = "postgres"
  engine_version          = "{{ postgres_version }}"
  instance_class          = "{{ instance_class }}"
  allocated_storage       = {{ allocated_storage }}
  storage_type            = "gp3"
  storage_encrypted       = true

  db_name  = "{{ db_name }}"
  username = "{{ username }}"
  password = random_password.db.result

  db_subnet_group_name   = aws_db_subnet_group.main.name
  vpc_security_group_ids = [aws_security_group.rds.id]
  parameter_group_name   = aws_db_parameter_group.main.name

  multi_az                = {{ "true" if multi_az else "false" }}
  backup_retention_period = {{ backup_retention_days }}
  skip_final_snapshot     = true
  deletion_protection     = false

  tags = merge(local.common_tags, {
    Name = "{{ db_name }}"
  })
}

resource "random_password" "db" {
  length           = 24
  special          = true
  override_special = "!#$%&*()-_=+[]{}<>:?"
}

# ---------------------------------------------------------------------------
# Outputs
# ---------------------------------------------------------------------------

output "db_endpoint" {
  description = "RDS instance endpoint."
  value       = aws_db_instance.main.endpoint
}

output "db_port" {
  description = "RDS instance port."
  value       = aws_db_instance.main.port
}

output "db_name" {
  description = "Database name."
  value       = aws_db_instance.main.db_name
}

output "db_username" {
  description = "Master username."
  value       = aws_db_instance.main.username
  sensitive   = true
}
